# MongoDB primary connection URI using mongodb+srv syntax (DNS SRV lookup).
# Required for the application to start.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# MongoDB database name. Defaults to "small-farmland" if not set.
MONGODB_DB=small-farmland

# MongoDB direct connection URI (optional fallback).
# Used if the primary MONGODB_URI experiences DNS/SRV resolution failures.
# Useful for local development or network-restricted environments.
MONGODB_URI_DIRECT=mongodb://<username>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/?ssl=true&replicaSet=<replicaSet>&authSource=admin&retryWrites=true&w=majority
